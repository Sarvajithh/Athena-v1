{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Athena",
  "version": "0.1.0",
  "identifier": "com.athena.app",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Athena",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Athena",
    "category": "Education",
    "shortDescription": "Athena — semester planning and adaptive study assistant",
    "longDescription": "Athena helps students plan a semester, track deadlines and trajectory, and get AI-assisted daily briefings and weekly plans, with an offline-first recommendation engine."
  }
}
