{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Athena",
  "version": "0.1.0",
  "identifier": "com.athena.app",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Athena",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
